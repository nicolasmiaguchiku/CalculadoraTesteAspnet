@implements IDialogContentComponent
@inject IHttpClientFactory HttpClientFactory

<FluentDialogHeader>
    <h3 class="text-center">Histórico de Cálculos</h3>
</FluentDialogHeader>

<FluentDialogBody>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Valor A</th>
                <th>Valor B</th>
                <th>Resultado</th>
                <th>Operação</th>
                <th>Data</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Calculations)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.ValueA</td>
                    <td>@item.ValueB</td>
                    <td>@item.Result</td>
                    <td>@item.Operation</td>
                    <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    <td>
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteAsync(item.Id)">Deletar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</FluentDialogBody>

@code {
    private List<CalculationDto> Calculations { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCalculationsAsync();
    }

    private async Task LoadCalculationsAsync()
    {
        var client = HttpClientFactory.CreateClient("CalcApi");
        var response = await client.GetAsync("Calculadora?apikey=NIC202604");

        Calculations = await response.Content.ReadFromJsonAsync<List<CalculationDto>>() ?? new();
    }

    private async Task DeleteAsync(int id)
    {
        var client = HttpClientFactory.CreateClient("CalcApi");
        var response = await client.DeleteAsync($"Calculadora?apikey=NIC202604&id={id}");

        await LoadCalculationsAsync();
    }
}